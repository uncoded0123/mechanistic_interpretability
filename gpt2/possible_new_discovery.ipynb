# [Cell 10] Circuit tracing — ablate each attention head, measure effect on SAE feature
# Same as partial derivative: zero one head, see how much target feature changes

TARGET_FEATURE = 10261  # Golden Gate feature from Cell 7
prompt = "The Golden Gate Bridge spans"

# Step 1: baseline — find which token has max activation for this feature
_, baseline_cache = model.run_with_cache(prompt)
baseline_x = baseline_cache["blocks.8.hook_resid_pre"]
baseline_acts = torch.relu((baseline_x - b_dec) @ W_enc + b_enc)

# Find token with strongest activation for this feature
tokens = model.to_str_tokens(prompt)
token_acts = baseline_acts[0, :, TARGET_FEATURE]
best_tok = token_acts.argmax().item()
baseline_val = token_acts[best_tok].item()

print(f"Feature {TARGET_FEATURE} activations per token:")
for i, tok in enumerate(tokens):
    print(f"  '{tok}': {token_acts[i].item():.3f}")
print(f"\nUsing token {best_tok} '{tokens[best_tok]}' (activation = {baseline_val:.3f})\n")
print(f"{'Layer':>5} {'Head':>5} | {'Ablated act':>11} | {'Change':>10} | Impact")
print("-" * 60)

# Step 2: only layers 0-7 matter (layer 8+ can't affect blocks.8.hook_resid_pre)
results = []
for layer in range(8):
    for head in range(model.cfg.n_heads):

        def ablate_head(value, hook, head_idx=head):
            value[:, :, head_idx, :] = 0
            return value

        with model.hooks(fwd_hooks=[(f"blocks.{layer}.attn.hook_result", ablate_head)]):
            _, abl_cache = model.run_with_cache(prompt)

        abl_x = abl_cache["blocks.8.hook_resid_pre"]
        abl_acts = torch.relu((abl_x - b_dec) @ W_enc + b_enc)
        abl_val = abl_acts[0, best_tok, TARGET_FEATURE].item()
        change = abl_val - baseline_val
        results.append((layer, head, abl_val, change))

# Sort by absolute impact
results.sort(key=lambda r: abs(r[3]), reverse=True)

max_change = max(abs(r[3]) for r in results)
for layer, head, abl_val, change in results[:20]:
    bar = "█" * int(abs(change) / max_change * 20) if max_change > 0 else ""
    direction = "▼" if change < 0 else "▲"
    print(f"  L{layer:>2}  H{head:>2}  | {abl_val:>11.3f} | {change:>+10.3f} | {direction} {bar}")
